FROM golang:1.23-alpine AS build

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/trendcortex-api ./cmd/api

FROM alpine:3.21

RUN apk add --no-cache ffmpeg
RUN addgroup -S app && adduser -S app -G app
WORKDIR /app

COPY --from=build /out/trendcortex-api /app/trendcortex-api

USER app

CMD ["/app/trendcortex-api"]
