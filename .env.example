# TrendCortex — Environment Variable Reference
# Copy this file to .env and fill in real values for local development.
# NEVER commit .env to git. The .gitignore already excludes it.
# NEVER prefix secrets with VITE_ — those are compiled into the browser bundle.

# ── Frontend (public, safe to expose) ─────────────────────────
# Leave empty for local dev through the Vite proxy. Set to the deployed API
# origin for production frontend builds, e.g. Railway backend URL.
VITE_API_BASE_URL=

# ── Server ────────────────────────────────────────────────────
PORT=8080
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:8080

# ── Backend artifact storage ─────────────────────────────────
# Optional. If unset, the backend writes runtime artifacts to the OS temp
# directory, e.g. /tmp/trendcortex/exports and /tmp/trendcortex/generated-media.
# Set these to a mounted volume or future object-storage staging path when
# exports need to persist across deployments/restarts.
EXPORT_DIR=
MEDIA_OUTPUT_DIR=

# ── Trend Discovery (backend-only) ────────────────────────────
# Leave TREND_DISCOVERY_PROVIDER empty for an honest provider_not_configured
# response. Set to google_trends_rss to read Google's public Trends RSS feed
# without OAuth or frontend secrets.
TREND_DISCOVERY_PROVIDER=
TREND_DISCOVERY_BASE_URL=https://trends.google.com/trending/rss
TREND_DISCOVERY_TIMEOUT=10s

# ── Database (Railway provides this automatically in production) ──
DATABASE_URL=

# ── Session & Encryption ──────────────────────────────────────
# SESSION_SECRET: random 64-character hex string
# TOKEN_ENCRYPTION_KEY: 32-byte AES-256 key (64 hex chars)
# Generate with: openssl rand -hex 32
SESSION_SECRET=
TOKEN_ENCRYPTION_KEY=

# ── YouTube / Google ──────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Enable: YouTube Data API v3
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ── TikTok ────────────────────────────────────────────────────
# Create at: https://developers.tiktok.com/
# Product: Content Posting API (requires app review)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── Meta (Instagram Reels, Facebook Reels, Threads) ──────────
# Create at: https://developers.facebook.com/apps/
# Products needed: Instagram Graph API, Facebook Login, Threads API
META_APP_ID=
META_APP_SECRET=

# ── X / Twitter ───────────────────────────────────────────────
# Create at: https://developer.twitter.com/en/portal/
# OAuth 2.0 Client ID + Secret (User Authentication Settings)
X_CLIENT_ID=
X_CLIENT_SECRET=
